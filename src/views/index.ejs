<%- include('encabezado') %> <%- include('menu') %>

<div class="content">
  <!-- ===== TOPBAR ===== -->
  <div
    class="topbar d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3"
  >
    <h4 class="mb-2 mb-md-0">Informacion del sistema</h4>
    <div>
      <span class="me-3">Administrador</span>
      <button class="btn btn-sm btn-danger">Salir</button>
    </div>
  </div>

  <!-- ===== TARJETAS ===== -->
  <div class="row g-3">
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card text-white bg-primary mb-3">
        <div class="card-body">
          <h5>Reparaciones pendientes</h5>
          <h2>120</h2>
          <p>Registrados</p>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card text-white bg-success mb-3">
        <div class="card-body">
          <h5>Reparaciones hechas</h5>
          <h2>58</h2>
          <p>Pendientes</p>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card text-white bg-warning mb-3">
        <div class="card-body">
          <h5>Técnicos</h5>
          <h2>34</h2>
          <p>Registrados</p>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
      <div class="card text-white bg-danger mb-3">
        <div class="card-body">
          <h5>Usuarios</h5>
          <h2>8</h2>
          <p>Registrados</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== TABLA ===== -->
  <!-- ===== TABLA ===== -->
<div class="card mt-4">
  <div class="card-header">
    Listado de Personas
  </div>

  <div class="card-body table-responsive">

    <table
      id="discursosTable"
      class="table table-striped table-bordered"
    >

      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre</th>
          <th>Apellidos</th>
          <th>Dirección</th>
          <th>Teléfono</th>
          <th>Acciones</th>
        </tr>
      </thead>

      <tbody>

        <% if (personas && personas.length > 0) { %>

          <% personas.forEach(persona => { %>

            <tr>

              <td>
                <%= persona.id_persona %>
              </td>

              <td>
                <%= persona.nom_persona %>
              </td>

              <td>
                <%= persona.apellidos %>
              </td>

              <td>
                <%= persona.direccion %>
              </td>

              <td>
                <%= persona.telefono %>
              </td>

            <td>

    <button
      class="btn btn-success btn-sm me-1"
    >
      Ver
    </button>

    <a
      href="/eliminar/<%= persona.id_persona %>"
      class="btn btn-danger btn-sm"
      onclick="return confirm('¿Desea eliminar este registro?')"
    >
      Eliminar
    </a>

</td>

            </tr>

          <% }) %>

        <% } else { %>

          <tr>
            <td colspan="6" class="text-center">
              No existen registros
            </td>
          </tr>

        <% } %>

      </tbody>

    </table>

  </div>
</div>
  <!-- fin .content -->
</div>
<%- include('pie') %>
